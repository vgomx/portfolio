---
import Base from '../../layouts/Base.astro';
import { TopBar, Footer } from '../../components/Chrome.jsx';
import { Tag } from '../../ds/components/core/Tag.jsx';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  return entries.map((e) => ({ params: { slug: e.data.slug } }));
}

const { slug } = Astro.params;
const entries = await getCollection('blog');
const entry = entries.find((e) => e.data.slug === slug);
if (!entry) return Astro.redirect('/notes');

const { Content } = await render(entry);
const note = entry.data;

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---
<Base title={`${note.title} — Vitor Gomes`} description={note.summary}>
  <TopBar activePage="notes" client:load />

  <div style="max-width: 720px; margin: 0 auto; padding: 80px 48px 120px;">
    <a href="/notes" style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-faint); text-decoration: none; display: inline-block; margin-bottom: 40px;">
      ← Notes
    </a>

    <div style="display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap;">
      {(note.tags || []).map((t) => <Tag size="sm" client:load>{t}</Tag>)}
    </div>

    <h1 style="font-size: clamp(28px, 4vw, 48px); font-weight: 700; line-height: 1.08; letter-spacing: -0.03em; margin: 0 0 24px;">
      {note.title}
    </h1>

    <p style="font-size: 18px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 32px; max-width: 54ch;">
      {note.summary}
    </p>

    <div style="font-family: var(--font-mono); font-size: 12px; color: var(--text-faint); letter-spacing: 0.06em; padding-top: 24px; border-top: 1px solid var(--border-hairline); margin-bottom: 56px;">
      {formatDate(note.date)}
    </div>

    <article class="note-body">
      <Content />
    </article>
  </div>

  <Footer client:load />
</Base>

<style>
  .note-body { color: var(--text-primary); }
  .note-body :global(p)  { font-size: 17px; line-height: 1.75; margin: 0 0 1.4em; }
  .note-body :global(h2) { font-size: 22px; font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; margin: 2.4em 0 0.8em; }
  .note-body :global(h3) { font-size: 18px; font-weight: 600; letter-spacing: -0.01em; margin: 2em 0 0.6em; }
  .note-body :global(ul), .note-body :global(ol) { font-size: 17px; line-height: 1.75; padding-left: 1.5em; margin: 0 0 1.4em; }
  .note-body :global(li) { margin-bottom: 0.4em; }
  .note-body :global(hr) { border: none; border-top: 1px solid var(--border-hairline); margin: 3em 0; }
  .note-body :global(strong) { font-weight: 600; }
  .note-body :global(em) { font-style: italic; color: var(--text-secondary); }
  .note-body :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .note-body :global(code) { font-family: var(--font-mono); font-size: 13px; background: var(--surface-subtle); padding: 2px 6px; border-radius: 4px; }
  .note-body :global(blockquote) { border-left: 3px solid var(--border-default); margin: 0 0 1.4em; padding: 0 0 0 20px; color: var(--text-secondary); font-style: italic; }
</style>
