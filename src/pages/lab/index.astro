---
import Base from '../../layouts/Base.astro';
import { TopBar, Footer, SiteBanner } from '../../components/Chrome.jsx';
import LabScreen from '../../components/LabScreen.jsx';
import { getCollection } from 'astro:content';

const entries = await getCollection('lab');
const experiments = entries
  .map((e) => ({ ...e.data }))
  .filter((p) => !p.hidden)
  .sort((a, b) => b.year - a.year || b.code.localeCompare(a.code));
---
<Base title="Lab — Vitor Gomes" description="Off-hours experiments, prototypes and toys — developed in the dark, launched live." theme="lab">
  <TopBar activePage="lab" client:load />
  <SiteBanner client:idle />
  <LabScreen experiments={experiments} client:load />
  <Footer client:idle />
</Base>
