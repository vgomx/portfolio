---
import Base from '../layouts/Base.astro';
import { TopBar, Footer, SiteBanner } from '../components/Chrome.jsx';
import HomeScreen from '../components/HomeScreen.jsx';
import { getCollection } from 'astro:content';

const entries = await getCollection('work');
const projects = entries
  .map((e) => ({ slug: e.data.slug, ...e.data }))
  .filter((p) => !p.hidden)
  .sort((a, b) => b.year - a.year);
---
<Base>
  <TopBar activePage="home" client:load />
  <SiteBanner client:idle />
  <HomeScreen projects={projects} client:load />
  <Footer client:idle />
</Base>
