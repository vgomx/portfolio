---
import Base from '../../layouts/Base.astro';
import { TopBar, Footer } from '../../components/Chrome.jsx';
import WorkScreen from '../../components/WorkScreen.jsx';
import { getCollection } from 'astro:content';

const entries = await getCollection('work');
const projects = entries
  .map((e) => ({ slug: e.data.slug, ...e.data }))
  .sort((a, b) => b.year - a.year);
---
<Base title="Work — Vitor Gomes">
  <TopBar activePage="work" client:load />
  <WorkScreen projects={projects} client:load />
  <Footer client:load />
</Base>
