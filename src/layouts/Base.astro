---
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Vitor Gomes — Product Designer', description = 'Product designer working across identity, interface and design systems.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      @import '/src/ds/tokens/fonts.css';
      @import '/src/ds/tokens/colors.css';
      @import '/src/ds/tokens/typography.css';
      @import '/src/ds/tokens/spacing.css';
      @import '/src/ds/tokens/keyframes.css';
      @import '/src/ds/styles.css';

      *, *::before, *::after { box-sizing: border-box; }
      body { margin: 0; background: var(--surface-page); color: var(--text-primary); font-family: var(--font-sans); }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
